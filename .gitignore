# -------------------------
# Generic Node/Python/Windows repo ignores
# -------------------------

# Node
node_modules/
npm-debug.log*
yarn-debug.log*
yarn-error.log*
pnpm-debug.log*

# Logs
logs/
*.log

# Build / output
dist/
build/
coverage/
tmp/
temp/

# Dependency directories
.pnpm-store/

# Python
__pycache__/
*.py[cod]
*$py.class
.pytest_cache/
.mypy_cache/
*.so

# Virtual environments
venv/
ENV/
env/
.env/
.venv/
venv.bak/

# Byte-compiled / packaging
*.egg-info/
pip-wheel-metadata/
*.egg

# Environment / secrets
.env
.env.local
.env.*
.env.example
.env.test
secrets.*
credentials.json
*.pem
*.key

# Databases
*.sqlite3
*.sqlite
*.db

# Machine learning / model artifacts
*.h5
*.hdf5
*.pt
*.pth
*.ckpt
*.pkl
*.joblib
models/
weights/
face_recognition_data/
face_data/

# Test model Markdown files (do not push test/demo model docs or temporary model notes)
# Add specific filenames that your project generates or uses for test-model docs.
test_model.md
model_test.md
sample_model.md
demo_model.md
*_model.md
model-*.md


# Model/test artifact directories
test_models/
test_models_output/
artifacts/
artifacts/*
model_outputs/
temp_models/
datasets/
data/
raw_data/

# IDEs and editors
.vscode/
.idea/
*.suo
*.user
*.sln
*.swp

# OS files
.DS_Store
Thumbs.db
desktop.ini

# Windows PowerShell history
ConsoleHost_history.txt

# Executables / binaries
*.exe
*.dll
*.so
*.class
*.o

# Misc
coverage/
htmlcov/
.cache/

# Ignore temporary or generated files commonly found in this repo
*.bak
*.tmp

# Ignore all Markdown files — user requested no .md pushed
*.md

# End of .gitignore

# Ignore local check script that may contain secrets
/check-test-user.js
