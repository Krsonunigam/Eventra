{
  "name": "eventra",
  "version": "1.0.0",
  "description": "Face Recognition enabled Event Management Portal",
  "main": "server.js",
  "engines": {
    "node": ">=20 <25"
  },
  "scripts": {
    "start": "node server.js",
    "dev": "concurrently \"npm run server\" \"npm run client\"",
    "server": "nodemon server.js",
    "client": "cd client && npm start",
    "build": "cd client && npm run build",
    "install-client": "cd client && npm install",
    "heroku-postbuild": "npm run install-client && npm run build",
    "create-admin": "node scripts/createAdmin.js",
    "migrate:firestore": "node scripts/migrateMongoToFirestore.js"
  },
  "dependencies": {
    "@sendgrid/mail": "^8.1.6",
    "axios": "^1.16.0",
    "bcryptjs": "^2.4.3",
    "canvas": "^2.11.2",
    "cloudinary": "^2.10.0",
    "compression": "^1.7.4",
    "cors": "^2.8.6",
    "crypto": "^1.0.1",
    "dotenv": "^16.3.1",
    "exceljs": "^4.4.0",
    "express": "^4.18.2",
    "express-rate-limit": "^6.10.0",
    "face-api.js": "^0.20.0",
    "firebase": "^12.13.0",
    "firebase-admin": "^13.9.0",
    "google-auth-library": "^10.6.2",
    "helmet": "^7.0.0",
    "jsonwebtoken": "^9.0.3",
    "jszip": "^3.10.1",
    "mongoose": "^9.6.2",
    "multer": "^1.4.5-lts.1",
    "nodemailer": "^8.0.7",
    "pdf-lib": "^1.17.1",
    "pdfkit": "^0.17.2",
    "qrcode": "^1.5.4",
    "razorpay": "^2.9.2",
    "react-webcam": "^7.2.0",
    "sharp": "^0.34.4",
    "socket.io": "^4.7.2",
    "whatsapp-web.js": "^1.22.2"
  },
  "devDependencies": {
    "concurrently": "^8.2.0",
    "nodemon": "^3.0.1"
  },
  "overrides": {
    "@tootallnate/once": "^3.0.1",
    "node-fetch": "^2.7.0",
    "tar": "^7.5.15"
  },
  "keywords": [
    "event-management",
    "face-recognition",
    "attendance-system",
    "mern-stack"
  ],
  "author": "Eventra Team",
  "license": "MIT"
}
